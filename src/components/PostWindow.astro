---
interface Props {
  title: string;
  pubDate: Date;
}

const { title, pubDate } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('en', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<article class="post-window">
  <div class="post-flow">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <time class="post-date" datetime={pubDate.toISOString()}>
        {dateFormatter.format(pubDate)}
      </time>
    </header>
    <div class="post-body scroll-window">
      <slot />
    </div>
  </div>
</article>
