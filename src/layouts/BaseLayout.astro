---
import SiteLogo from '../components/SiteLogo.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  pageKind?: 'home' | 'post';
  image?: string;
}

const defaultDescription =
  'A minimal platform documenting my weekly learning progress & monologues';

const {
  title = 'write.hani',
  description = defaultDescription,
  pageKind = 'home',
  image = '/og-image.png',
} = Astro.props;

const site = Astro.site ?? new URL('https://write.hani.page');
const pageDescription = description.trim() || defaultDescription;
const canonicalUrl = new URL(Astro.url.pathname, site);
const imageUrl = new URL(image, site);
const socialType = pageKind === 'post' ? 'article' : 'website';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:site_name" content="write.hani" />
    <meta property="og:type" content={socialType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={imageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={imageUrl.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500&family=Goudy+Bookletter+1911&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class={pageKind === 'post' ? 'is-post-page' : ''}>
    <SiteLogo />
    <slot />
  </body>
</html>
